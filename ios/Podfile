# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

# Match Xcode build configuration names so CocoaPods generates the right xcfilelists per flavor.
project 'TestBareBootStrapWorkflow.xcodeproj', {
  'Debug' => :debug,
  'Release' => :release,
  'Debug-Dev' => :debug,
  'Release-Dev' => :release,
  'Debug-QA' => :debug,
  'Release-QA' => :release,
  'Debug-Prod' => :debug,
  'Release-Prod' => :release,
}

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'TestBareBootStrapWorkflow' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'TestBareBootStrapWorkflowTests' do
    inherit! :search_paths
  end

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # react-native-mmkv → MMKVCore ships OpenSSL C++ under the pod; with modular
    # headers / framework-module builds, Clang errors on non-modular includes.
    installer.pods_project.targets.each do |target|
      next unless target.name == 'MMKVCore'

      target.build_configurations.each do |build_config|
        build_config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      end
    end

    # react-native-config iOS codegen reads ENV['ENVFILE'] or defaults to `.env` at repo root.
    # App-target xcconfig ENVFILE does not propagate to the Pod build, so set it per configuration here.
    installer.pods_project.targets.each do |target|
      next unless target.name == 'react-native-config'

      target.build_configurations.each do |build_config|
        name = build_config.name
        env_path = case name
                   when 'Debug-Dev', 'Release-Dev'
                     '$(PODS_ROOT)/../../.env.dev'
                   when 'Debug-QA', 'Release-QA'
                     '$(PODS_ROOT)/../../.env.qa'
                   when 'Debug-Prod', 'Release-Prod'
                     '$(PODS_ROOT)/../../.env.prod'
                   else
                     '$(PODS_ROOT)/../../.env.dev'
                   end
        build_config.build_settings['ENVFILE'] = env_path
      end
    end

  end
end
