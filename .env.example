# Copy this file to `.env.dev`, `.env.qa`, and `.env.prod` in the project root (those files are gitignored).
# Optionally copy to `.env` for a single local override.
# Android: `android/app/build.gradle` merges the matching file per variant (`devDebug` → `.env.dev`, …).
# iOS: `ios/Podfile` `post_install` points the react-native-config Pod at the right file per Xcode configuration.
# Never commit files containing real secrets.

API_BASE_URL=https://api.example.com/
APP_ENV=development
